# GitHub token (CLI/stdio mode only)
GITHUB_PERSONAL_ACCESS_TOKEN=

# HTTP server: Self-Hosted mode
# Required for self-hosted /mcp access and analytics protection
MCP_API_KEY=

# HTTP server: Key Service mode (hosted usr_... resolution)
KEY_SERVICE_URL=
KEY_SERVICE_TOKEN=

# Optional: CORS origins (comma-separated)
ALLOWED_ORIGINS=

# Optional: Public base path when mounted under a reverse-proxy subpath
# Example: /github
PUBLIC_BASE_PATH=

# Optional: MCP protocol version
MCP_PROTOCOL_VERSION=2025-11-25

# Optional: Diagnostics and tracing
MCP_TRACE_HTTP=false
ENABLE_MCP_DIAGNOSTICS=false
ENABLE_SMITHERY_ENDPOINT=false

# Optional: Analytics storage directory
ANALYTICS_DIR=/app/data
