{
	"name": "mcp-github",
	"version": "2.0.0",
	"description": "MCP server for interacting with GitHub - supports CLI, self-hosted VPS, Smithery, and hosted key-service modes",
	"license": "MIT",
	"author": "hithereiamaliff",
	"type": "module",
	"bin": {
		"mcp-github": "dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "smithery build",
		"build:tsc": "tsc",
		"dev": "smithery dev",
		"dev:http": "npx tsx src/http-server.ts",
		"start:http": "node dist/http-server.js",
		"cli": "node dist/cli.js",
		"check": "npx @biomejs/biome check --write --unsafe"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/hithereiamaliff/mcp-github.git"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"github",
		"github-api",
		"ai-tools"
	],
	"bugs": {
		"url": "https://github.com/hithereiamaliff/mcp-github/issues"
	},
	"homepage": "https://github.com/hithereiamaliff/mcp-github#readme",
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.18.2",
		"@smithery/sdk": "^1.6.4",
		"cors": "^2.8.5",
		"express": "^4.21.0",
		"octokit": "^4.1.3",
		"zod": "^3.25.46"
	},
	"module": "src/index.ts",
	"devDependencies": {
		"@cfworker/json-schema": "^4.1.1",
		"@smithery/cli": "^1.6.2",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^22.10.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	}
}
